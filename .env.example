# =============================================================================
# OpenJarvis — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
#
# For Docker deployment, also copy deploy/docker/.env.example:
#   cp deploy/docker/.env.example deploy/docker/.env
# =============================================================================

# ─── Core Configuration ─────────────────────────────────────────────────────

# API Key for authenticating requests to the OpenJarvis server.
# Generate one with: jarvis auth generate-key
OPENJARVIS_API_KEY=change-me-to-a-secure-key

# Log level: debug, info, warning, error
OPENJARVIS_LOG_LEVEL=info

# Enable development mode (hot reload, debug features)
OPENJARVIS_DEV_MODE=false

# ─── Engine Configuration ───────────────────────────────────────────────────

# Default inference engine: ollama, openai, anthropic, google, litellm
OPENJARVIS_ENGINE_DEFAULT=ollama

# Ollama host (when using Docker, use the service name)
OLLAMA_HOST=http://localhost:11434

# OpenAI / Anthropic / Google API keys (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ─── Database Configuration ─────────────────────────────────────────────────

# Database URL (SQLite by default, PostgreSQL supported)
# SQLite:      sqlite:////path/to/db.sqlite
# PostgreSQL:  postgresql://user:password@host:5432/dbname
# Migration progressive : commencez avec SQLite, migrez vers PostgreSQL quand prêt.
OPENJARVIS_DATABASE_URL=sqlite:////var/lib/openjarvis/memory/openjarvis.db

# PostgreSQL (optional — only needed if using PostgreSQL)
# Service Docker : host = "postgres", port = 5432
POSTGRES_ENABLED=true
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=openjarvis
POSTGRES_USER=openjarvis
POSTGRES_PASSWORD=change-me-in-production

# ─── Vector Store Configuration ─────────────────────────────────────────────

# ChromaDB (simple / dev) — mémoire long terme, embeddings, recherche sémantique
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Qdrant (production) — base vectorielle haute performance pour gros volumes
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ─── Cache & Queue Configuration ────────────────────────────────────────────

# Redis host and port (optional)
REDIS_HOST=localhost
REDIS_PORT=6379

# Enable/disable Redis service in Docker Compose
REDIS_ENABLED=true

# Enable Redis persistence (RDB/AOF)
REDIS_PERSISTENCE=false

# ─── Telemetry Configuration ────────────────────────────────────────────────

# PostHog telemetry (optional — leave empty to disable)
POSTHOG_API_KEY=
POSTHOG_HOST=

# ─── Ollama Configuration ───────────────────────────────────────────────────

# Enable/disable Ollama service in Docker Compose
OLLAMA_ENABLED=true

# Default model to pull on first startup
OLLAMA_MODEL=llama3.2

# Ollama API port
OLLAMA_PORT=11434

# How long to keep models loaded in memory (e.g., 5m, 1h, 24h)
OLLAMA_KEEP_ALIVE=5m

# Number of parallel requests
OLLAMA_NUM_PARALLEL=1

# Maximum number of loaded models
OLLAMA_MAX_LOADED_MODELS=1

# Enable debug logging for Ollama
OLLAMA_DEBUG=0

# ─── Port Configuration ─────────────────────────────────────────────────────

# OpenJarvis API server port (direct access, bypass Traefik)
OPENJARVIS_PORT=8000

# Nginx / Frontend port (direct access, bypass Traefik)
NGINX_PORT=80

# Vite dev server port (development only)
VITE_PORT=5173

# ─── Traefik Configuration ──────────────────────────────────────────────────

# Traefik reverse proxy (principal)
TRAEFIK_ENABLED=true
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8080
TRAEFIK_DASHBOARD_ENABLED=true
TRAEFIK_LOG_LEVEL=INFO

# Let's Encrypt (production SSL)
# Configurez ces valeurs pour activer le SSL automatique
TRAEFIK_ACME_EMAIL=admin@example.com
TRAEFIK_ACME_DOMAIN=example.com

# ─── Prometheus Configuration ───────────────────────────────────────────────

# Prometheus monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=10GB

# ─── Grafana Configuration ──────────────────────────────────────────────────

# Grafana visualization
GRAFANA_ENABLED=true
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production
GRAFANA_ROOT_URL=http://localhost:3000

# ─── Path Configuration ─────────────────────────────────────────────────────

# Workspace directory for file operations
OPENJARVIS_WORKSPACE=/workspace

# Upload directory
OPENJARVIS_UPLOADS=/var/lib/openjarvis/uploads

# Cache directory
OPENJARVIS_CACHE=/var/lib/openjarvis/cache

# Models directory
OPENJARVIS_MODELS=/var/lib/openjarvis/models