# =============================================================================
# Ethan OS — Configuration Environment
# =============================================================================
#
# Instructions:
#   1. Copier ce fichier : cp .env.example .env
#   2. Modifier les valeurs selon votre environnement
#   3. Ne JAMAIS commit de fichier .env contenant des secrets
#
# Pour le développement complet :
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up
#
# Pour la production :
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up
# =============================================================================

# ─── Core Configuration ──────────────────────────────────────────────────────

# API Key pour authentifier les requêtes vers le serveur Ethan
# Générer avec : jarvis auth generate-key
ETHAN_API_KEY=change-me-to-a-secure-key

# Niveau de log : debug, info, warning, error
ETHAN_LOG_LEVEL=info

# Mode développement (hot reload, fonctionnalités debug)
ETHAN_DEV_MODE=false


# ─── Engine Configuration ────────────────────────────────────────────────────

# Moteur d'inférence par défaut : ollama, openai, anthropic, google, litellm
ETHAN_ENGINE_DEFAULT=ollama

# Ollama host (en Docker, utiliser le nom du service)
# Pour dev complet (interne) : http://ollama:11434
# Pour accès direct (debug) : http://localhost:11434
OLLAMA_HOST=http://ollama:11434

# Ollama base URL (alias pour OLLAMA_HOST)
OLLAMA_BASE_URL=http://localhost:11434

# Clés API pour services cloud (optionnel)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=


# ─── Database Configuration ──────────────────────────────────────────────────

# URL de base de données (SQLite par défaut, PostgreSQL supporté)
# SQLite : sqlite:////path/to/db.sqlite
# PostgreSQL : postgresql://user:password@host:5432/dbname
ETHAN_DATABASE_URL=sqlite:////var/lib/ethan/memory/ethan.db

# PostgreSQL (optionnel — seulement si utilisation de PostgreSQL)
# En Docker : host = "postgres", port = 5432
POSTGRES_ENABLED=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ethan
POSTGRES_USER=ethan
POSTGRES_PASSWORD=change-me-in-production


# ─── Cache Configuration (Redis) ─────────────────────────────────────────────

# Redis host et port (nom du service Docker en mode compose)
REDIS_HOST=redis
REDIS_PORT=6379

# Activer/désactiver Redis dans Docker Compose
REDIS_ENABLED=false

# Activer la persistance Redis (RDB/AOF)
REDIS_PERSISTENCE=false


# ─── Vector Store Configuration ──────────────────────────────────────────────

# Qdrant (production) — base de données vectorielle
# En Docker : http://qdrant:6333
QDRANT_URL=http://qdrant:6333
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ChromaDB (simple / dev) — alternative pour développement
CHROMA_HOST=localhost
CHROMA_PORT=8000


# ─── Ollama Configuration ────────────────────────────────────────────────────

# Activer/désactiver Ollama dans Docker Compose
OLLAMA_ENABLED=false

# Modèle par défaut à télécharger au premier démarrage
OLLAMA_MODEL=llama3.2

# Port API Ollama
OLLAMA_PORT=11434

# Durée de conservation des modèles en mémoire (ex: 5m, 1h, 24h)
OLLAMA_KEEP_ALIVE=5m

# Nombre de requêtes parallèles
OLLAMA_NUM_PARALLEL=1

# Nombre maximum de modèles chargés
OLLAMA_MAX_LOADED_MODELS=1

# Activer les logs debug pour Ollama
OLLAMA_DEBUG=0


# ─── Port Configuration ──────────────────────────────────────────────────────

# Port du serveur API Ethan (accès direct, sans Traefik)
ETHAN_PORT=8000

# Port Nginx / Frontend (accès direct, sans Traefik)
NGINX_PORT=3000

# Port du serveur dev Vite (développement uniquement)
VITE_PORT=5173


# ─── Traefik Configuration (Production) ──────────────────────────────────────

# Reverse proxy Traefik (production uniquement)
TRAEFIK_ENABLED=false
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8080
TRAEFIK_DASHBOARD_ENABLED=true
TRAEFIK_LOG_LEVEL=INFO

# Let's Encrypt (SSL production)
TRAEFIK_ACME_EMAIL=admin@example.com
TRAEFIK_ACME_DOMAIN=example.com


# ─── Prometheus Configuration (Production) ───────────────────────────────────

# Monitoring Prometheus
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=10GB


# ─── Grafana Configuration (Production) ──────────────────────────────────────

# Visualisation Grafana
GRAFANA_ENABLED=false
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production
GRAFANA_ROOT_URL=http://localhost:3000


# ─── Path Configuration ──────────────────────────────────────────────────────

# Répertoire workspace pour opérations fichiers
ETHAN_WORKSPACE=/workspace

# Répertoire uploads
ETHAN_UPLOADS=/var/lib/ethan/uploads

# Répertoire cache
ETHAN_CACHE=/var/lib/ethan/cache

# Répertoire modèles
ETHAN_MODELS=/var/lib/ethan/models