<content>#!/usr/bin/env python3
"""ETHAN CLI — minimal terminal client for XFCE4.

Usage:
  ethan <message>    One-shot send
  ethan chat         Interactive REPL
  ethan status       System status

Backend:
  POST http://localhost:8000/message
  GET  http://localhost:8000/state
"""
import os
import sys
from urllib.request import Request, urlopen

API = os.environ.get("ETHAN_API", "http://localhost:8000")
HIST = os.path.expanduser("~/.ethan_history")


def send(msg: str) -> str:
    payload = f'{{"content": "{msg}"}}'.encode()
    req = Request(f"{API}/message", data=payload,
                  headers={"Content-Type": "application/json"}, method="POST")
    with urlopen(req, timeout=10) as r:
        data = __import__("json").loads(r.read())
        return data.get("response", data.get("error", "no response"))


def alive() -> bool:
    try:
        with urlopen(f"{API}/state", timeout=3) as r:
            return r.status == 200
    except Exception:
        return False


def cmd_send(args):
    if not args:
        print("usage: ethan <message>")
        sys.exit(1)
    text = " ".join(args)
    if not alive():
        print(f"ERR: ETHAN unreachable at {API}")
        sys.exit(1)
    print(send(text))


def cmd_chat():
    if not alive():
        print(f"ERR: ETHAN unreachable at {API}")
        sys.exit(1)
    print("ETHAN chat — Ctrl+D or 'exit' to quit")
    print("-" * 40)
    while True:
        try:
            msg = input(">>> ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            break
        if not msg:
            continue
        if msg.lower() in ("exit", "quit", "q"):
            break
        print(send(msg))
        with open(HIST, "a") as f:
            f.write(f">>> {msg}\n{send(msg)}\n\n")


def cmd_status():
    try:
        with urlopen(f"{API}/state", timeout=5) as r:
            s = __import__("json").loads(r.read())
        print(f"Mode:  {s.get('mode', '?')}")
        print(f"Goal:  {s.get('active_goal', 'none')}")
        print(f"Tasks: {s.get('running_tasks', 0)}")
    except Exception:
        print(f"ERR: cannot reach {API}")


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print(f"ETHAN CLI — {API}")
        print("  ethan <message>   One-shot send")
        print("  ethan chat        Interactive REPL")
        print("  ethan status      System status")
        sys.exit(0)
    cmd = sys.argv[1]
    args = sys.argv[2:]
    if cmd == "chat":
        cmd_chat()
    elif cmd == "status":
        cmd_status()
    else:
        cmd_send([cmd] + args)


if __name__ == "__main__":
    main()