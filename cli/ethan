#!/usr/bin/env python3
"""ETHAN unified CLI — toolchain entrypoint."""
import sys
from registry import dispatch, discover_commands, _get_handler


# Auto-discover all commands — no hardcoded imports
discover_commands()

if __name__ == "__main__":
    argv = sys.argv[1:]
    if not argv or argv[0] in ("-h", "--help"):
        argv = ["help"]
    elif _get_handler(argv[0]) is None:
        argv = ["run"] + argv
    sys.exit(dispatch(argv))