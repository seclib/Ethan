#!/usr/bin/env python3
"""ETHAN unified CLI — toolchain entrypoint."""
import sys
from registry import dispatch, discover_commands, COMMANDS, register


@register("version")
def cmd_version(args):
    print("ethan 2.0")
    return 0


@register("help")
def cmd_help(args):
    print("ETHAN toolchain")
    print("Commands:", " ".join(sorted(COMMANDS)))
    return 0


# Auto-discover all commands — no hardcoded imports
discover_commands()

if __name__ == "__main__":
    argv = sys.argv[1:]
    if not argv or argv[0] in ("-h", "--help"):
        argv = ["help"]
    elif argv[0] not in COMMANDS:
        argv = ["run"] + argv
    sys.exit(dispatch(argv))
